{
  "id": "swarmbench-01",
  "description": "Deterministic scheduler replay for wait-any speedup, lock gating, dedup merge, and retry behavior.",
  "scheduler": {
    "lane_caps": {
      "runner": 2,
      "builder": 4,
      "inspector": 1
    },
    "retry_delay_s": 1,
    "max_retries_by_agent": {
      "runner": 1,
      "builder": 0,
      "inspector": 0
    }
  },
  "files": {
    "initial_dispatches": "dispatches.initial.json",
    "handoff_requests": {
      "sb01--runner-map": "handoff.runner-map.json",
      "sb01--runner-failure": "handoff.runner-failure.json"
    }
  },
  "durations_s": {
    "sb01--runner-map": 2,
    "sb01--runner-failure": 2,
    "sb01--builder-long": 12,
    "sb01--builder-short": 3,
    "sb01--builder-after-short": 4,
    "sb01--builder-lock-a": 5,
    "sb01--builder-lock-b": 2
  },
  "fail_attempts": {
    "sb01--runner-failure": [
      1
    ]
  },
  "expectations": {
    "min_max_parallel": 3,
    "min_lock_conflicts": 1,
    "min_dedup_merged": 1,
    "min_retry_count": 1,
    "min_reuse_count": 2,
    "expected_wait_any_makespan_s": 12,
    "expected_wait_all_makespan_s": 19,
    "min_wait_any_speedup_s": 4,
    "expected_completed_slice_ids": [
      "sb01--runner-map",
      "sb01--runner-failure",
      "sb01--builder-long",
      "sb01--builder-short",
      "sb01--builder-after-short",
      "sb01--builder-lock-a",
      "sb01--builder-lock-b"
    ]
  }
}
