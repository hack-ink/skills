{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "review-result.inspector/1",
  "title": "review-result.inspector/1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "ssot_id", "task_id", "slice_id", "verdict", "findings"],
  "properties": {
    "schema": { "const": "review-result.inspector/1" },
    "ssot_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*-[0-9a-f]{8,64}$"
    },
    "task_id": { "type": "string", "minLength": 1 },
    "slice_id": { "type": "string", "minLength": 1 },
    "agent_type": {
      "const": "inspector",
      "description": "Canonical agent identity field for /1 results. New outputs should emit agent_type."
    },
    "role": {
      "const": "inspector",
      "description": "Accepted /1 identity alias field; do not emit on new outputs."
    },
    "verdict": { "type": "string", "enum": ["PASS", "BLOCK", "NEEDS_EVIDENCE"] },
    "review_mode": {
      "type": "string",
      "enum": ["spec_compliance", "code_quality", "final_closeout"]
    },
    "summary": { "type": "string" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "message"],
        "properties": {
          "severity": { "type": "string", "enum": ["info", "minor", "major", "critical"] },
          "category": { "type": "string", "minLength": 1 },
          "confidence": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "message": { "type": "string", "minLength": 1 },
          "evidence": { "type": "string" },
          "paths": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "default": []
          }
        }
      }
    },
    "review_notes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "required_fixes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "required_evidence": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    }
  },
  "allOf": [
    { "anyOf": [{ "required": ["agent_type"] }, { "required": ["role"] }] },
    {
      "if": { "properties": { "verdict": { "const": "BLOCK" } } },
      "then": { "properties": { "required_fixes": { "minItems": 1 } } }
    },
    {
      "if": { "properties": { "verdict": { "const": "NEEDS_EVIDENCE" } } },
      "then": { "properties": { "required_evidence": { "minItems": 1 } } }
    }
  ],
  "examples": [
    {
      "schema": "review-result.inspector/1",
      "ssot_id": "e2e-write-4aeb119f4748",
      "task_id": "e2e",
      "slice_id": "inspector-1",
      "agent_type": "inspector",
      "verdict": "PASS",
      "review_mode": "final_closeout",
      "summary": "Protocol rules are followed and evidence is sufficient.",
      "review_notes": [
        "Checked schema-valid worker outputs and aligned them with playbook constraints."
      ],
      "findings": [
        {
          "severity": "info",
          "category": "topology",
          "confidence": "high",
          "message": "max_depth=1 broker model prevents same-level spawns.",
          "paths": ["multi-agent/PLAYBOOK.md"]
        }
      ]
    }
  ]
}
