{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "worker-result.runner/1",
  "title": "worker-result.runner/1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "ssot_id", "task_id", "slice_id", "status", "summary"],
  "anyOf": [{ "required": ["agent_type"] }, { "required": ["role"] }],
  "properties": {
    "schema": { "const": "worker-result.runner/1" },
    "ssot_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*-[0-9a-f]{8,64}$"
    },
    "task_id": { "type": "string", "minLength": 1 },
    "slice_id": { "type": "string", "minLength": 1 },
    "agent_type": {
      "const": "runner",
      "description": "Canonical agent identity field for /1 results. New outputs should emit agent_type."
    },
    "role": {
      "const": "runner",
      "description": "Accepted /1 identity alias field; do not emit on new outputs."
    },
    "status": { "type": "string", "enum": ["done", "blocked", "partial"] },
    "summary": { "type": "string", "minLength": 1 },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "analysis": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        },
        "commands": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["cmd", "exit_code"],
            "properties": {
              "cmd": { "type": "string", "minLength": 1 },
              "cwd": { "type": "string", "minLength": 1 },
              "exit_code": { "type": "integer" },
              "stdout_excerpt": { "type": "string" },
              "stderr_excerpt": { "type": "string" }
            }
          },
          "default": []
        },
        "files_read": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        }
      },
      "default": {}
    },
    "recovery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["checkpoint"],
      "properties": {
        "blocked_reason": { "type": "string", "minLength": 1 },
        "required_evidence": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        },
        "required_decisions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        },
        "checkpoint": {
          "type": "object",
          "additionalProperties": false,
          "required": ["state", "last_action", "next_steps"],
          "properties": {
            "state": { "type": "string", "minLength": 1 },
            "last_action": { "type": "string", "minLength": 1 },
            "resume_from": { "type": "string", "minLength": 1 },
            "next_steps": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "minItems": 1,
              "maxItems": 3
            }
          }
        }
      }
    },
    "next_actions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "handoff_requests": {
      "type": "array",
      "items": { "$ref": "task-dispatch/1" },
      "default": []
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "blocked" } } },
      "then": {
        "required": ["recovery"],
        "properties": {
          "recovery": { "required": ["blocked_reason", "checkpoint"] }
        }
      }
    },
    {
      "if": { "properties": { "status": { "const": "partial" } } },
      "then": { "required": ["recovery"] }
    }
  ],
  "examples": [
    {
      "schema": "worker-result.runner/1",
      "ssot_id": "e2e-read-04c9d864d719",
      "task_id": "e2e",
      "slice_id": "runner-1",
      "agent_type": "runner",
      "status": "done",
      "summary": "Confirmed schemas validate locally and listed files to update.",
      "evidence": {
        "analysis": [
          "Schema examples are internally consistent and the builder handoff can stay scoped to one file."
        ],
        "commands": [
          {
            "cmd": "python3 dev/multi-agent/e2e/run_smoke.py",
            "cwd": "<repo_root>",
            "exit_code": 0,
            "stdout_excerpt": "OK: schema + examples ..."
          }
        ],
        "files_read": ["multi-agent/SKILL.md"]
      },
      "next_actions": ["Proceed to builder slice to implement changes."],
      "handoff_requests": [
        {
          "schema": "task-dispatch/1",
          "ssot_id": "e2e-read-04c9d864d719",
          "task_id": "e2e",
          "slice_id": "builder-1",
          "agent_type": "builder",
          "slice_kind": "work",
          "work_package_id": "pkg-builder-1",
          "timebox_minutes": 10,
          "ownership_paths": ["multi-agent/schemas/worker-result.builder.schema.json"],
          "dependencies": ["runner-1"],
          "task_contract": {
            "goal": "Apply the agreed schema update.",
            "acceptance": ["Schema validates with Draft202012Validator."],
            "constraints": ["Do not modify docs or e2e fixtures."]
          },
          "evidence_requirements": ["diff", "verification"]
        }
      ]
    }
  ]
}
