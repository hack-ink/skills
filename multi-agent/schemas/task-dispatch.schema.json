{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "task-dispatch/1",
  "title": "task-dispatch/1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "ssot_id",
    "task_id",
    "slice_id",
    "agent_type",
    "timebox_minutes",
    "task_contract"
  ],
  "properties": {
    "schema": { "const": "task-dispatch/1" },
    "ssot_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*-[0-9a-f]{8,64}$"
    },
    "task_id": { "type": "string", "minLength": 1 },
    "slice_id": { "type": "string", "minLength": 1 },
    "agent_type": {
      "type": "string",
      "enum": ["runner", "builder", "inspector"]
    },
    "slice_kind": {
      "type": "string",
      "enum": ["probe", "work", "review"],
      "default": "work"
    },
    "work_package_id": { "type": "string", "minLength": 1 },
    "timebox_minutes": { "type": "integer", "minimum": 1, "maximum": 60 },
    "ownership_paths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "task_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["goal", "acceptance", "constraints"],
      "properties": {
        "goal": { "type": "string", "minLength": 1 },
        "acceptance": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "constraints": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        }
      }
    },
    "evidence_requirements": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "analysis",
          "commands",
          "diff",
          "files_read",
          "git_diff",
          "review_notes",
          "verification"
        ]
      },
      "uniqueItems": true,
      "default": []
    }
  },
  "examples": [
    {
      "schema": "task-dispatch/1",
      "ssot_id": "e2e-write-4aeb119f4748",
      "task_id": "e2e",
      "slice_id": "builder-1",
      "agent_type": "builder",
      "slice_kind": "work",
      "work_package_id": "pkg-builder-1",
      "timebox_minutes": 12,
      "ownership_paths": ["multi-agent/schemas/"],
      "dependencies": [],
      "task_contract": {
        "goal": "Add a new schema file.",
        "acceptance": ["Schema validates with Draft202012Validator."],
        "constraints": ["Do not edit unrelated directories."]
      },
      "evidence_requirements": ["commands", "verification"]
    }
  ],
  "allOf": [
    {
      "if": { "properties": { "agent_type": { "const": "builder" } } },
      "then": {
        "required": ["work_package_id", "ownership_paths"],
        "properties": {
          "ownership_paths": { "minItems": 1 }
        }
      }
    },
    {
      "if": {
        "properties": { "agent_type": { "enum": ["runner", "inspector"] } }
      },
      "then": {
        "properties": {
          "ownership_paths": { "maxItems": 0 }
        }
      }
    }
  ]
}
