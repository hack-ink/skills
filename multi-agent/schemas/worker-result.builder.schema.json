{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "worker-result.builder/1",
  "title": "worker-result.builder/1",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "task_dispatch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema",
        "ssot_id",
        "task_id",
        "slice_id",
        "agent_type",
        "timebox_minutes",
        "allowed_paths",
        "ownership_paths",
        "task_contract"
      ],
      "properties": {
        "schema": { "const": "task-dispatch/1" },
        "ssot_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*-[0-9a-f]{8,64}$"
        },
        "task_id": { "type": "string", "minLength": 1 },
        "slice_id": { "type": "string", "minLength": 1 },
        "agent_type": {
          "type": "string",
          "enum": ["runner", "builder", "inspector"]
        },
        "slice_kind": {
          "type": "string",
          "enum": ["probe", "work", "review", "merge"],
          "default": "work"
        },
        "work_package_id": { "type": "string", "minLength": 1 },
        "expected_work_s": { "type": "integer", "minimum": 0 },
        "timebox_minutes": { "type": "integer", "minimum": 1, "maximum": 60 },
        "allowed_paths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        },
        "ownership_paths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        },
        "task_contract": {
          "type": "object",
          "additionalProperties": false,
          "required": ["goal", "acceptance", "constraints"],
          "properties": {
            "goal": { "type": "string", "minLength": 1 },
            "acceptance": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "minItems": 1
            },
            "constraints": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "default": []
            },
            "no_touch": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "default": []
            }
          }
        },
        "evidence_requirements": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        }
      },
      "allOf": [
        {
          "if": { "properties": { "agent_type": { "const": "builder" } } },
          "then": {
            "required": ["work_package_id", "expected_work_s"],
            "properties": {
              "allowed_paths": { "minItems": 1 },
              "ownership_paths": { "minItems": 1 }
            }
          }
        }
      ]
    }
  },
  "required": [
    "schema",
    "ssot_id",
    "task_id",
    "slice_id",
    "role",
    "status",
    "summary",
    "allowed_paths",
    "changeset",
    "verification"
  ],
  "properties": {
    "schema": { "const": "worker-result.builder/1" },
    "ssot_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*-[0-9a-f]{8,64}$"
    },
    "task_id": { "type": "string", "minLength": 1 },
    "slice_id": { "type": "string", "minLength": 1 },
    "role": { "const": "builder" },
    "agent_type": { "type": "string", "enum": ["builder"] },
    "status": { "type": "string", "enum": ["done", "blocked", "partial"] },
    "summary": { "type": "string", "minLength": 1 },
    "allowed_paths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "changeset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["touched_paths"],
      "properties": {
        "touched_paths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        }
      }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["cmd", "exit_code"],
        "properties": {
          "cmd": { "type": "string", "minLength": 1 },
          "cwd": { "type": "string", "minLength": 1 },
          "exit_code": { "type": "integer" },
          "stdout_excerpt": { "type": "string" },
          "stderr_excerpt": { "type": "string" }
        }
      },
      "minItems": 1
    },
    "handoff_requests": {
      "type": "array",
      "items": { "$ref": "#/$defs/task_dispatch" },
      "default": []
    }
  },
  "examples": [
    {
      "schema": "worker-result.builder/1",
      "ssot_id": "e2e-write-4aeb119f4748",
      "task_id": "e2e",
      "slice_id": "builder-1",
      "role": "builder",
      "agent_type": "builder",
      "status": "done",
      "summary": "Updated multi-agent playbook and schemas; smoke tests pass.",
      "allowed_paths": ["multi-agent/"],
      "changeset": {
        "touched_paths": ["multi-agent/PLAYBOOK.md", "multi-agent/schemas/task-dispatch.schema.json"]
      },
      "verification": [
        {
          "cmd": "python3 dev/multi-agent/e2e/run_smoke.py",
          "cwd": "<repo_root>",
          "exit_code": 0,
          "stdout_excerpt": "OK: e2e fixtures + invariants"
        }
      ],
      "handoff_requests": [
        {
          "schema": "task-dispatch/1",
          "ssot_id": "e2e-write-4aeb119f4748",
          "task_id": "e2e",
          "slice_id": "inspector-1",
          "agent_type": "inspector",
          "slice_kind": "review",
          "timebox_minutes": 6,
          "allowed_paths": [],
          "ownership_paths": [],
          "dependencies": ["builder-1"],
          "task_contract": {
            "goal": "Review the produced evidence and risk profile.",
            "acceptance": ["Return PASS/BLOCK/NEEDS_EVIDENCE with findings."],
            "constraints": ["Review-only output.", "No repository edits."],
            "no_touch": []
          },
          "evidence_requirements": ["review_notes"]
        }
      ]
    }
  ]
}
