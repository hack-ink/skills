{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "worker-result.builder/1",
  "title": "worker-result.builder/1",
  "description": "Builder result contract for route=multi. /1 accepts role=\"builder\" as an identity alias; builder-required fields such as work_package_id remain mandatory for all /1 payloads. status=partial is reserved for landed edits that provide a salvageable checkpoint rather than a generic in-progress note.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "ssot_id",
    "task_id",
    "slice_id",
    "work_package_id",
    "status",
    "summary",
    "ownership_paths"
  ],
  "anyOf": [{ "required": ["agent_type"] }, { "required": ["role"] }],
  "properties": {
    "schema": { "const": "worker-result.builder/1" },
    "ssot_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*-[0-9a-f]{8,64}$"
    },
    "task_id": { "type": "string", "minLength": 1 },
    "slice_id": { "type": "string", "minLength": 1 },
    "work_package_id": {
      "type": "string",
      "minLength": 1,
      "description": "Required on every /1 builder result, including payloads that use the role alias."
    },
    "agent_type": {
      "const": "builder",
      "description": "Canonical agent identity field for /1 results. New outputs should emit agent_type."
    },
    "role": {
      "const": "builder",
      "description": "Accepted /1 identity alias. This does not relax builder-required fields such as work_package_id; do not emit role on new outputs."
    },
    "status": { "type": "string", "enum": ["done", "blocked", "partial"] },
    "summary": { "type": "string", "minLength": 1 },
    "ownership_paths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "changeset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["touched_paths"],
      "properties": {
        "touched_paths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "diff_summary": { "type": "string", "minLength": 1 },
        "git_diff_summary": { "type": "string", "minLength": 1 }
      },
      "default": {}
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["cmd", "exit_code"],
        "properties": {
          "cmd": { "type": "string", "minLength": 1 },
          "cwd": { "type": "string", "minLength": 1 },
          "exit_code": { "type": "integer" },
          "stdout_excerpt": { "type": "string" },
          "stderr_excerpt": { "type": "string" }
        }
      },
      "minItems": 1
    },
    "recovery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["checkpoint"],
      "properties": {
        "blocked_reason": { "type": "string", "minLength": 1 },
        "required_evidence": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        },
        "required_decisions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        },
        "checkpoint": {
          "type": "object",
          "additionalProperties": false,
          "required": ["state", "last_action", "next_steps"],
          "properties": {
            "state": { "type": "string", "minLength": 1 },
            "last_action": { "type": "string", "minLength": 1 },
            "resume_from": { "type": "string", "minLength": 1 },
            "next_steps": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "minItems": 1,
              "maxItems": 3
            }
          }
        }
      }
    },
    "handoff_requests": {
      "type": "array",
      "items": { "$ref": "task-dispatch/1" },
      "default": []
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "done" } } },
      "then": { "required": ["changeset", "verification"] }
    },
    {
      "if": { "properties": { "status": { "const": "blocked" } } },
      "then": {
        "required": ["recovery"],
        "properties": {
          "recovery": { "required": ["blocked_reason", "checkpoint"] }
        }
      }
    },
    {
      "if": { "properties": { "status": { "const": "partial" } } },
      "then": {
        "required": ["changeset", "recovery"],
        "properties": {
          "recovery": {
            "properties": {
              "checkpoint": { "required": ["resume_from"] }
            }
          }
        },
        "anyOf": [
          { "required": ["verification"] },
          {
            "properties": {
              "recovery": {
                "required": ["required_evidence"],
                "properties": {
                  "required_evidence": {
                    "contains": { "const": "verification" }
                  }
                }
              }
            }
          }
        ]
      }
    }
  ],
  "examples": [
    {
      "schema": "worker-result.builder/1",
      "ssot_id": "e2e-write-4aeb119f4748",
      "task_id": "e2e",
      "slice_id": "builder-1",
      "work_package_id": "pkg-builder-1",
      "agent_type": "builder",
      "status": "done",
      "summary": "Updated multi-agent playbook and schemas; smoke tests pass.",
      "ownership_paths": ["multi-agent/"],
      "changeset": {
        "touched_paths": ["multi-agent/PLAYBOOK.md", "multi-agent/schemas/task-dispatch.schema.json"]
      },
      "evidence": {
        "diff_summary": "Updated builder routing and result schema examples.",
        "git_diff_summary": "PLAYBOOK.md plus task-dispatch.schema.json changed in the owned slice."
      },
      "verification": [
        {
          "cmd": "python3 dev/multi-agent/e2e/run_smoke.py",
          "cwd": "<repo_root>",
          "exit_code": 0,
          "stdout_excerpt": "OK: e2e fixtures + invariants"
        }
      ],
      "handoff_requests": [
        {
          "schema": "task-dispatch/1",
          "ssot_id": "e2e-write-4aeb119f4748",
          "task_id": "e2e",
          "slice_id": "inspector-1",
          "agent_type": "inspector",
          "slice_kind": "review",
          "timebox_minutes": 6,
          "dependencies": ["builder-1"],
          "task_contract": {
            "goal": "Review the produced evidence and risk profile.",
            "acceptance": ["Return PASS/BLOCK/NEEDS_EVIDENCE with findings."],
            "constraints": ["Review-only output.", "No repository edits."]
          },
          "evidence_requirements": ["review_notes"]
        }
      ]
    },
    {
      "schema": "worker-result.builder/1",
      "ssot_id": "e2e-write-4aeb119f4748",
      "task_id": "e2e-write_mixed",
      "slice_id": "builder-01",
      "work_package_id": "pkg-write-builder-01",
      "agent_type": "builder",
      "status": "partial",
      "summary": "Applied the safe subset and returned a salvage checkpoint for the same owned package.",
      "ownership_paths": ["multi-agent/schemas/"],
      "changeset": {
        "touched_paths": ["multi-agent/schemas/worker-result.builder.schema.json"],
        "notes": [
          "Resume from the landed workspace state instead of replaying the schema edits."
        ]
      },
      "recovery": {
        "required_evidence": ["verification"],
        "checkpoint": {
          "state": "partial",
          "last_action": "Updated the builder partial contract and saved the current checkpoint.",
          "resume_from": "Continue inside the same owned package from the saved schema edits.",
          "next_steps": [
            "Finish the remaining schema-aligned validator updates.",
            "Run the local smoke/backtest bundle.",
            "Return the final done result once verification is attached."
          ]
        }
      }
    }
  ]
}
